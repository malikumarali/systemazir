# Supabase Configuration (Get these from your Supabase Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Server-side Service Role Key (Keep this secret! Never prefixes with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# NVIDIA LLM API Key (For the sidebar Nemotron AI Chatbot assistant)
NVIDIA_API_KEY=your_nvidia_api_key_here
